/// Prisma schema for the B2B Marketplace platform (Phase 0.2)
/// Contains core entities, relationships, indexes, and JSON fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("DIRECT_URL")
}

/// User roles within the platform
enum Role {
  SELLER
  BUYER
  ADMIN
}

/// Granular admin sub-roles (M21)
enum AdminRole {
  SUPER_ADMIN
  ADMIN
  REVIEWER
  FINANCE
  SUPPORT
}

/// Seller company types
enum CompanyType {
  PROPRIETORSHIP
  PRIVATE_LIMITED
  LLP
}

/// Seller business model (Module 8)
enum BusinessModel {
  MANUFACTURER
  WHOLESALER
  DISTRIBUTOR
  RETAILER
}

/// KYC status for sellers
enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Product availability status
enum AvailabilityStatus {
  IN_STOCK
  OUT_OF_STOCK
}

/// Admin approval status for entities
enum AdminApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Buy lead preferred contact channel
enum ContactChannel {
  WHATSAPP
  TELEGRAM
  EMAIL
}

/// Buy lead repeat options
enum RepeatOption {
  NONE
  WEEKLY
  MONTHLY
}

/// Requirement type for buyer posts (Module 16)
enum RequirementType {
  RETAIL
  WHOLESALE
}

/// Currency for target price (Module 16)
enum Currency {
  INR
  USD
}

/// Lead credit transaction types
enum LeadCreditTxnType {
  PURCHASE
  SPEND
  REFUND
}

/// Order status lifecycle
enum OrderStatus {
  QUOTED
  ACCEPTED
  REJECTED
  FULFILLED
  CANCELLED
}

/// Payment status for orders
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

/// Quote status
enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// Admin approval entity types
enum AdminEntityType {
  SELLER_KYC
  PRODUCT_LISTING
  BUYER_FRAUD
}

/// Audit actions captured by the audit log
enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

/// Users table (PII)
/// - Purpose: Stores platform users (buyers, sellers, admins)
/// - Relationships: One-to-many with Sellers, Buyers, and AdminApprovals (as admin)
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phoneNumber     String?   @unique
  passwordHash    String
  role            Role      @default(BUYER)
  adminRole       AdminRole?
  isActive        Boolean   @default(true)
  phoneVerified   Boolean   @default(false)
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  twoFaSecret     String?
  twoFaEnabled    Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sellers          Seller[]
  buyers           Buyer[]
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  adminApprovals   AdminApproval[]  @relation("AdminApprovalsByAdmin")
  approvedProducts Product[]        @relation("ProductApprovedBy")
  auditLogs        AuditLog[]
  notificationPreferences NotificationPreferences?
  reportedTickets    ComplaintTicket[]         @relation("TicketsByReporter")
  receivedTickets    ComplaintTicket[]         @relation("TicketsByReportedUser")
  ticketResponses    ComplaintTicketResponse[] @relation("TicketResponsesByAdmin")
  consentRecords     ConsentRecord[]
  dataExportRequests DataExportRequest[]

  @@index([role, isActive])
}

/// Sellers table
/// - Purpose: Company-level details for user accounts acting as sellers
/// - PII/Sensitive: gstNumber, panNumber
model Seller {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id])
  companyName   String
  companyType   CompanyType
  iecCode       String?
  gstNumber     String?
  panNumber     String?
  isVerified    Boolean    @default(false)
  kycStatus     KycStatus  @default(PENDING)
  approvalDate  DateTime?
  rejectionReason String?

  // Address fields
  registeredOfficeAddress String?
  businessOfficeAddress   String?
  city                    String?
  state                   String?   // Required for Module 2 state filtering
  pincode                 String?
  country                 String    @default("India")

  // Module 8 KYC fields
  industryType            String[]
  businessModel           BusinessModel?
  hasIEC                  Boolean   @default(false)
  udyamNumber             String?
  directorName            String?
  directorDesignation     String?
  directorPan             String?
  directorPhoto           String?
  aadhaarLastFour         String?   // UIDAI: only last 4 digits stored
  logoUrl                 String?   // WebP logo stored at /uploads/logos/{id}.webp (Module 14)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  products            Product[]
  leadCreditWallet    LeadCreditWallet?
  leadContactReveals  LeadContactReveal[]
  orders              Order[]            @relation("OrdersBySeller")
  quotes              Quote[]
  creditTransactions  LeadCreditTransaction[]
  kycDocuments        SellerKycDocument[]
  savedLeads          SellerSavedLead[]

  @@index([gstNumber, panNumber])
  @@index([isVerified, kycStatus])
  @@index([state])  // <-- ADD STATE INDEX FOR FILTERING 
}

/// Buyers table
/// - Purpose: Business/customer details for buyers
enum BusinessType {
  COMPANY
  TRADER
  CONSUMER
}

model Buyer {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  businessType BusinessType
  gstinNumber  String?
  companyName  String?
  isVerified   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  buyLeads       BuyLead[]
  orders         Order[]              @relation("OrdersByBuyer")
  savedSellers   BuyerSavedSeller[]
  savedProducts  BuyerSavedProduct[]
}

/// Module 19: Buyer watchlist — saved products
model BuyerSavedProduct {
  id        String   @id @default(cuid())
  buyerId   String
  buyer     Buyer    @relation(fields: [buyerId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  savedAt   DateTime @default(now())

  @@unique([buyerId, productId])
  @@index([buyerId, savedAt(sort: Desc)])
}

/// Buyer watchlist — saved sellers (bookmarked)
model BuyerSavedSeller {
  id       String   @id @default(cuid())
  buyerId  String
  buyer    Buyer    @relation(fields: [buyerId], references: [id])
  sellerId String
  savedAt  DateTime @default(now())

  @@unique([buyerId, sellerId])
  @@index([buyerId, savedAt(sort: Desc)])
}

/// Categories table
/// - Purpose: Product categorization with self-referencing hierarchy
model Category {
  id           String      @id @default(cuid())
  name         String      @unique
  parentId     String?
  parent       Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]  @relation("CategoryHierarchy")
  industryType String[]
  description  String?
  createdAt    DateTime    @default(now())

  productLinks ProductCategory[]
  buyLeads     BuyLead[]
}

/// Products table
/// - Purpose: Catalog of items offered by sellers
/// - Sensitive: certifications may include regulatory data (Public/Regulated)
model Product {
  id                    String               @id @default(cuid())
  sellerId              String
  seller                Seller               @relation(fields: [sellerId], references: [id])
  name                  String
  description           String?
  hsnCode               String?
  unit                  String?
  multiTierPricing      Json
  images                Json?
  certifications        Json?
  countryOfOrigin       String?
  partModelNumber       String?
  minimumOrderQuantity  Decimal?             @db.Decimal(18, 4)
  taxPercentage         Decimal?             @db.Decimal(5, 2)
  tags                  String[]
  buyersPreferredFrom   String[]
  manufacturerName      String?
  manufacturerCountry   String?
  aboutManufacturer     String?
  stockedInCountry      String?
  stockedInQuantity     Decimal?             @db.Decimal(18, 4)
  stockedInType         String?
  estimatedShippingDays Int?
  availabilityStatus    AvailabilityStatus   @default(IN_STOCK)
  isActive              Boolean              @default(true)
  adminApprovalStatus   AdminApprovalStatus  @default(PENDING)
  approvedBy            String?
  approvedByUser        User?                @relation("ProductApprovedBy", fields: [approvedBy], references: [id])
  approvalDate          DateTime?
  isFlagged             Boolean              @default(false)
  flagReason            String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deletedAt             DateTime?

  categories    ProductCategory[]
  orders        Order[]
  quotes        Quote[]
  viewTracking  ProductViewTracking[]
  savedByBuyers BuyerSavedProduct[]

  @@index([sellerId, isActive])
  @@index([adminApprovalStatus, createdAt(sort: Desc)])
}

/// Junction table: Products <-> Categories
model ProductCategory {
  productId  String
  categoryId String

  product Product  @relation(fields: [productId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
}

/// Buy leads posted by buyers for sourcing products
/// - PII may appear in remarks but core fields are non-PII
model BuyLead {
  id               String        @id @default(cuid())
  buyerId          String
  buyer            Buyer         @relation(fields: [buyerId], references: [id])
  productName      String
  quantity         Decimal?      @db.Decimal(18, 4)
  unit             String?
  quantityRequired Int?
  targetPriceMin   Decimal?      @db.Decimal(18, 2)
  targetPriceMax   Decimal?      @db.Decimal(18, 2)
  expectedCountry  String?
  contactChannel   ContactChannel
  isOpen           Boolean       @default(true)
  expiryDate       DateTime?
  repeatOption     RepeatOption  @default(NONE)
  /// Module 16 — Post Buy Requirement
  requirementType  RequirementType?
  currency         Currency      @default(INR)
  deliveryState    String?
  additionalNotes  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  expiresAt        DateTime?
  deletedAt        DateTime?

  /// Category for smart seller-matching (Module 12)
  categoryId     String?
  category       Category?           @relation(fields: [categoryId], references: [id])

  contactReveals LeadContactReveal[]
  savedBy        SellerSavedLead[]
  quotes         Quote[]

  @@index([buyerId])
  @@index([expiryDate])
  @@index([createdAt(sort: Desc)])
  @@index([categoryId, isOpen, expiryDate])
}

/// Lead credit wallet for sellers
model LeadCreditWallet {
  id               String   @id @default(cuid())
  sellerId         String   @unique
  seller           Seller   @relation(fields: [sellerId], references: [id])
  balance          Decimal  @db.Decimal(18, 2) @default(0)
  totalPurchased   Decimal  @db.Decimal(18, 2) @default(0)
  totalSpent       Decimal  @db.Decimal(18, 2) @default(0)
  lastRechargeDate DateTime?
  lowBalanceThreshold Int    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  transactions LeadCreditTransaction[]
}

/// Transactions in the lead credit wallet
model LeadCreditTransaction {
  id                 String             @id @default(cuid())
  sellerId           String
  seller             Seller             @relation(fields: [sellerId], references: [id])
  walletId           String?
  wallet             LeadCreditWallet?  @relation(fields: [walletId], references: [id])
  type               LeadCreditTxnType
  /// Number of credits purchased or spent
  credits            Int                @default(0)
  /// Legacy: total amount field (kept for backward compat)
  amount             Decimal            @db.Decimal(18, 2)
  /// Pre-GST base amount (for PURCHASE transactions)
  baseAmount         Decimal?           @db.Decimal(18, 2)
  /// GST amount at 18% (for PURCHASE transactions)
  gstAmount          Decimal?           @db.Decimal(18, 2)
  /// Total charged including GST
  totalAmount        Decimal?           @db.Decimal(18, 2)
  /// Credit pack identifier (starter | standard | pro | enterprise)
  packId             String?
  /// Razorpay order ID created before payment
  razorpayOrderId    String?
  /// Razorpay payment ID — unique, used as idempotency key
  razorpayPaymentId  String?            @unique
  /// Transaction status
  status             String             @default("COMPLETED")
  /// Path to generated GST invoice file
  invoicePath        String?
  /// Formatted invoice number: B2B-YYYY-MM-NNNN
  invoiceNumber      String?
  orderId            String?
  timestamp          DateTime           @default(now())
  referenceId        String?            @unique
  createdAt          DateTime           @default(now())
  /// GSTN IRP Invoice Reference Number (64-char hash) — set when IRP e-invoice is registered
  irn                String?
  /// IRP acknowledgement number returned by GSTN portal
  ackNo              String?
  /// Signed QR code data returned by IRP (to be printed on invoice)
  irpQrCode          String?            @db.Text

  @@index([sellerId, type])
  @@index([walletId])
  @@index([razorpayOrderId])
  @@index([status])
}

/// Contact reveal records when a seller spends credits to view buyer details
/// - PII: buyerPhoneNumber, buyerEmail, buyerWhatsapp (Encrypted at application layer)
model LeadContactReveal {
  id                String    @id @default(cuid())
  sellerId          String
  seller            Seller    @relation(fields: [sellerId], references: [id])
  buyLeadId         String
  buyLead           BuyLead   @relation(fields: [buyLeadId], references: [id])
  buyerPhoneNumber  String
  buyerEmail        String
  buyerWhatsapp     String
  buyerGstin        String?
  creditDeducted    Boolean   @default(true)
  /// Module 12: seller marks whether this reveal led to a conversion
  convertedToOrder  Boolean   @default(false)
  convertedAt       DateTime?
  timestamp         DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@index([sellerId, buyLeadId])
  @@index([sellerId, convertedToOrder])
}

/// Orders between buyers and sellers
model Order {
  id                     String        @id @default(cuid())
  buyerId                String
  buyer                  Buyer         @relation("OrdersByBuyer", fields: [buyerId], references: [id])
  sellerId               String
  seller                 Seller        @relation("OrdersBySeller", fields: [sellerId], references: [id])
  productId              String?
  product                Product?      @relation(fields: [productId], references: [id])
  status                 OrderStatus   @default(QUOTED)
  quotedPrice            Decimal?      @db.Decimal(18, 2)
  negotiatedPrice        Decimal?      @db.Decimal(18, 2)
  finalPrice             Decimal?      @db.Decimal(18, 2)
  platformFacilitationFee Decimal?     @db.Decimal(18, 2)
  paymentStatus          PaymentStatus @default(PENDING)
  paymentMethod          String?
  razorpayOrderId        String?
  razorpayPaymentId      String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?

  quotes Quote[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([paymentStatus])
  @@index([createdAt(sort: Desc)])
}

/// Price quote for an order provided by a seller
model Quote {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  sellerId    String
  seller      Seller      @relation(fields: [sellerId], references: [id])
  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  /// Module 17: back-link to the originating buy requirement so buyer
  /// can group quotes by requirement. Nullable for legacy quotes.
  buyLeadId   String?
  buyLead     BuyLead?    @relation(fields: [buyLeadId], references: [id])
  quotedPrice Decimal     @db.Decimal(18, 2)
  leadTime    String?
  notes       String?
  status      QuoteStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?

  negotiations NegotiationMessage[]

  @@index([orderId])
  @@index([sellerId, status])
  @@index([buyLeadId, status])
}

/// Module 17: Back-and-forth negotiation messages on a Quote
enum NegotiationRole {
  BUYER
  SELLER
}

model NegotiationMessage {
  id           String          @id @default(cuid())
  quoteId      String
  quote        Quote           @relation(fields: [quoteId], references: [id])
  fromRole     NegotiationRole
  counterPrice Decimal?        @db.Decimal(18, 2)
  message      String
  createdAt    DateTime        @default(now())

  @@index([quoteId, createdAt(sort: Desc)])
}

/// Admin approvals for entities
model AdminApproval {
  id          String           @id @default(cuid())
  adminId     String
  admin       User             @relation("AdminApprovalsByAdmin", fields: [adminId], references: [id])
  entityType  AdminEntityType
  entityId    String
  status      AdminApprovalStatus @default(PENDING)
  submittedAt DateTime          @default(now())
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime          @default(now())

  @@index([adminId, entityType])
  @@index([entityId, status])
}

/// Audit log capturing all mutations (compliance/forensics)
/// - PII may be present in oldValue/newValue snapshots
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     AuditAction
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime    @default(now())
  createdAt  DateTime    @default(now())

  @@index([userId, entityType])
  @@index([entityId, action])
  @@index([createdAt(sort: Desc)])
}

/// Notification preferences for a user
model NotificationPreferences {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id])
  emailNotifications     Boolean  @default(true)
  smsNotifications       Boolean  @default(false)
  whatsappNotifications  Boolean  @default(false)
  pushNotifications      Boolean  @default(false)
  /// Per-event-type overrides: { NEW_LEAD: { email: true, sms: false, whatsapp: true }, ... }
  eventPreferences       Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

/// Module 20: Complaint categories
enum ComplaintCategory {
  FRAUD
  PRODUCT_QUALITY
  PAYMENT
  DELIVERY
  OTHER
}

/// Complaint/support ticket (Module 20)
model ComplaintTicket {
  id             String            @id @default(cuid())
  reporterId     String
  reporter       User              @relation("TicketsByReporter", fields: [reporterId], references: [id])
  reportedUserId String
  reportedUser   User              @relation("TicketsByReportedUser", fields: [reportedUserId], references: [id])
  category       ComplaintCategory @default(OTHER)
  subject        String
  description    String
  status         ComplaintStatus   @default(OPEN)
  attachments    Json?
  /// SLA deadline: createdAt + 48 h (Consumer Protection Rules 2020)
  slaDeadline    DateTime?
  slaBreach      Boolean           @default(false)
  adminNotes     String?
  orderId        String?
  escalatedAt    DateTime?
  escalatedTo    String?   // Admin user ID of senior admin
  escalatedBy    String?   // Admin user ID who escalated
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  responses ComplaintTicketResponse[]

  @@index([reporterId])
  @@index([status, createdAt(sort: Desc)])
  @@index([slaBreach, status])
  @@index([createdAt(sort: Desc)])
}

/// Admin responses on a complaint ticket
model ComplaintTicketResponse {
  id          String          @id @default(cuid())
  ticketId    String
  ticket      ComplaintTicket @relation(fields: [ticketId], references: [id])
  responderId String
  responder   User            @relation("TicketResponsesByAdmin", fields: [responderId], references: [id])
  message     String
  isInternal  Boolean         @default(false) // Internal admin notes — not shown to complainant
  createdAt   DateTime        @default(now())

  @@index([ticketId, createdAt(sort: Desc)])
}

/// Grievance Officer contact form — required by IT Act / DPDP Act (public, no auth)
model GrievanceContact {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String
  description String
  category    String   @default("OTHER")
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([status, createdAt(sort: Desc)])
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Feature flags with audience targeting
model FeatureFlag {
  id                String   @id @default(cuid())
  name              String   @unique
  isEnabled         Boolean  @default(false)
  rolloutPercentage Int      @default(0)
  targetAudience    Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Search query analytics log (Module 5)
model SearchLog {
  id               String   @id @default(cuid())
  query            String
  resultsCount     Int      @default(0)
  filters          Json?
  userId           String?
  ipAddress        String?
  /// CTR tracking: set when a result is clicked via POST /api/search/track-click
  clickedProductId String?
  resultPosition   Int?
  timestamp        DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([query])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

/// Seller watchlist — saved buy leads (no credit cost, Module 12)
model SellerSavedLead {
  id       String   @id @default(cuid())
  sellerId String
  seller   Seller   @relation(fields: [sellerId], references: [id])
  leadId   String
  lead     BuyLead  @relation(fields: [leadId], references: [id])
  savedAt  DateTime @default(now())

  @@unique([sellerId, leadId])
  @@index([sellerId, savedAt(sort: Desc)])
}

/// Product view tracking for analytics
model ProductViewTracking {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  viewCount    Int      @default(1)
  lastViewedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([productId])
  @@index([lastViewedAt(sort: Desc)])
}

/// In-app notifications for sellers and buyers (Module 9)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // KYC_APPROVED | KYC_REJECTED | NEW_ORDER | NEW_LEAD | LOW_BALANCE | PRODUCT_APPROVED | GENERAL
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?  // deep-link to relevant page
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

/// Refresh tokens for sliding JWT sessions (Module 8)
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

/// Module 25: Fraud block list — email/phone/IP entries that are blocked platform-wide
model BlockList {
  id          String   @id @default(cuid())
  email       String?
  phoneNumber String?
  ipAddress   String?
  userId      String?
  reason      String
  blockedBy   String
  blockedAt   DateTime @default(now())
  unblockedAt DateTime?
  isActive    Boolean  @default(true)
  notes       String?

  @@index([email])
  @@index([phoneNumber])
  @@index([userId])
  @@index([isActive, blockedAt(sort: Desc)])
}

/// Module 27: DPDP Act 2023 — User consent records
/// Legal basis: DPDP Act §6 (informed & specific consent), §7 (deemed consent for essential services)
model ConsentRecord {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  consentType   String    // ESSENTIAL | MARKETING | ANALYTICS | DATA_SHARING
  version       String    // Policy version at time of consent, e.g. "v2024.1"
  givenAt       DateTime  @default(now())
  ipAddress     String?
  userAgent     String?
  withdrawnAt   DateTime?

  @@index([userId, consentType])
  @@index([userId, givenAt(sort: Desc)])
}

/// Module 27: DPDP Act §12 — Data portability export requests
model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  status      String    @default("QUEUED") // QUEUED | PROCESSING | READY | EXPIRED | FAILED
  fileUrl     String?   // Signed path valid 24h; null until ready
  expiresAt   DateTime?
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  errorMsg    String?

  @@index([userId, requestedAt(sort: Desc)])
  @@index([status])
}

/// Module 27: DPDP Act §13 — Grievance Officer tickets (legal obligation; distinct from support tickets)
/// 72-hour response SLA mandated by DPDP Act §13(3)
model GrievanceTicket {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String
  description     String
  category        String    // DATA_BREACH | CONSENT | ERASURE | CORRECTION | PORTABILITY | OTHER
  userId          String?   // null for unauthenticated filers
  status          String    @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  slaDeadline     DateTime  // givenAt + 72h
  slaBreach       Boolean   @default(false)
  responseNotes   String?
  respondedAt     DateTime?
  respondedBy     String?   // Admin user ID
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, slaDeadline])
  @@index([email])
  @@index([createdAt(sort: Desc)])
}

/// Module 26: Homepage promotional banners (CMS-managed)
model HomepageBanner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, sortOrder])
  @@index([startDate, endDate])
}

/// Module 26: Lead credit pack configurations (admin-managed pricing)
model CreditPackConfig {
  id        String   @id @default(cuid())
  name      String
  credits   Int
  priceInr  Int
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// Module 26: Prohibited keyword registry (admin-managed)
model ProhibitedKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  addedBy   String
  addedAt   DateTime @default(now())

  @@index([keyword])
  @@index([addedAt(sort: Desc)])
}

/// Module 26: Notification templates (bilingual EN + HI)
model NotificationTemplate {
  id         String   @id @default(cuid())
  key        String   @unique // e.g. KYC_APPROVED, NEW_ORDER
  titleEn    String
  bodyEn     String
  titleHi    String
  bodyHi     String
  variables  String[] // placeholder names: ["sellerName", "amount"]
  isActive   Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  @@index([key])
}

/// KYC documents uploaded by sellers (Module 8)
/// Files stored on server disk, NOT publicly accessible
model SellerKycDocument {
  id           String   @id @default(cuid())
  sellerId     String
  seller       Seller   @relation(fields: [sellerId], references: [id])
  documentType String   // GST_CERTIFICATE | PAN_CARD | IEC_CERTIFICATE | UDYAM | ISO | DRUG_LICENCE | FSSAI | DIRECTOR_PHOTO
  fileUrl      String   // Server path (private)
  fileName     String
  fileSize     Int      // bytes
  mimeType     String
  uploadedAt   DateTime @default(now())

  @@index([sellerId, documentType])
}
